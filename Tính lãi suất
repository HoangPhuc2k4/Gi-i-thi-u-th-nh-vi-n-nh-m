import 'dart:math';
import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        useMaterial3: true,
        brightness: Brightness.dark,
        colorSchemeSeed: Colors.cyanAccent,
      ),
      home: const DoubleMoneyUI(),
    );
  }
}

class DoubleMoneyUI extends StatefulWidget {
  const DoubleMoneyUI({super.key});

  @override
  State<DoubleMoneyUI> createState() => _DoubleMoneyUIState();
}

class _DoubleMoneyUIState extends State<DoubleMoneyUI> {
  final moneyController = TextEditingController();
  final rateController = TextEditingController();
  
  double years = 0;
  double finalAmount = 0;
  double totalInterest = 0;

  void calculate() {
    double money = double.tryParse(moneyController.text) ?? 0;
    double rate = double.tryParse(rateController.text) ?? 0;

    if (money > 0 && rate > 0) {
      double r = rate / 100;
      setState(() {
        years = log(2) / log(1 + r);
        finalAmount = money * 2; // Mục tiêu là gấp đôi
        totalInterest = money;    // Tiền lãi bằng đúng tiền gốc
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF0F172A), // Màu nền Navy tối
      body: CustomScrollView(
        slivers: [
          // AppBar kiểu hiện đại
          const SliverAppBar(
            expandedHeight: 120,
            floating: true,
            backgroundColor: Color(0xFF0F172A),
            flexibleSpace: FlexibleSpaceBar(
              title: Text("INVESTMENT AI", 
                style: TextStyle(letterSpacing: 2, fontWeight: FontWeight.w900, fontSize: 16)),
              centerTitle: true,
            ),
          ),
          
          SliverToBoxAdapter(
            child: Padding(
              padding: const EdgeInsets.symmetric(horizontal: 20),
              child: Column(
                children: [
                  // --- KHU VỰC NHẬP LIỆU ---
                  _buildGlassCard(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        const Text("Thiết lập mục tiêu", 
                          style: TextStyle(color: Colors.cyanAccent, fontWeight: FontWeight.bold)),
                        const SizedBox(height: 20),
                        _buildModernInput(moneyController, "Vốn đầu tư ban đầu", Icons.account_balance_wallet),
                        const SizedBox(height: 15),
                        _buildModernInput(rateController, "Lãi suất kỳ vọng (%/năm)", Icons.bolt),
                        const SizedBox(height: 25),
                        _buildGradientButton(),
                      ],
                    ),
                  ),
                  
                  const SizedBox(height: 30),

                  // --- KHU VỰC KẾT QUẢ ---
                  if (years > 0) ...[
                    _buildMainResultCard(),
                    const SizedBox(height: 20),
                    _buildAnalysisSection(),
                    const SizedBox(height: 40),
                  ],
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  // Widget Thẻ kính mờ
  Widget _buildGlassCard({required Widget child}) {
    return Container(
      padding: const EdgeInsets.all(24),
      decoration: BoxDecoration(
        color: Colors.white.withValues(alpha: 0.05),
        borderRadius: BorderRadius.circular(30),
        border: Border.all(color: Colors.white.withValues(alpha: 0.1)),
      ),
      child: child,
    );
  }

  // Widget Ô nhập liệu Modern
  Widget _buildModernInput(TextEditingController controller, String label, IconData icon) {
    return TextField(
      controller: controller,
      keyboardType: TextInputType.number,
      style: const TextStyle(color: Colors.white, fontSize: 18),
      decoration: InputDecoration(
        labelText: label,
        labelStyle: const TextStyle(color: Colors.white60, fontSize: 14),
        prefixIcon: Icon(icon, color: Colors.cyanAccent, size: 20),
        filled: true,
        fillColor: Colors.black.withValues(alpha: 0.2),
        enabledBorder: OutlineInputBorder(
          borderRadius: BorderRadius.circular(15),
          borderSide: BorderSide.none,
        ),
        focusedBorder: OutlineInputBorder(
          borderRadius: BorderRadius.circular(15),
          borderSide: const BorderSide(color: Colors.cyanAccent, width: 1),
        ),
      ),
    );
  }

  // Nút bấm Gradient
  Widget _buildGradientButton() {
    return InkWell(
      onTap: calculate,
      child: Container(
        height: 60,
        width: double.infinity,
        decoration: BoxDecoration(
          borderRadius: BorderRadius.circular(15),
          gradient: const LinearGradient(
            colors: [Color(0xFF00F2FE), Color(0xFF4FACFE)],
          ),
          boxShadow: [
            BoxShadow(
              color: const Color(0xFF4FACFE).withValues(alpha: 0.3),
              blurRadius: 15,
              offset: const Offset(0, 8),
            )
          ],
        ),
        child: const Center(
          child: Text("BẮT ĐẦU PHÂN TÍCH", 
            style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold, fontSize: 16)),
        ),
      ),
    );
  }

  // Thẻ kết quả chính
  Widget _buildMainResultCard() {
    return Container(
      width: double.infinity,
      padding: const EdgeInsets.all(30),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(30),
        gradient: const LinearGradient(
          begin: Alignment.topLeft,
          end: Alignment.bottomRight,
          colors: [Color(0xFF1E293B), Color(0xFF334155)],
        ),
      ),
      child: Column(
        children: [
          const Text("THỜI GIAN NHÂN ĐÔI TÀI SẢN", 
            style: TextStyle(color: Colors.white60, letterSpacing: 1, fontSize: 12)),
          const SizedBox(height: 10),
          Text("${years.toStringAsFixed(1)} Năm", 
            style: const TextStyle(
              fontSize: 56, 
              fontWeight: FontWeight.w900, // Sửa lỗi FontWeight.black
              color: Colors.white,
              shadows: [Shadow(color: Colors.cyanAccent, blurRadius: 20)],
            )),
          const SizedBox(height: 10),
          const Icon(Icons.keyboard_double_arrow_down, color: Colors.cyanAccent),
        ],
      ),
    );
  }

  // Khu vực phân tích chi tiết
  Widget _buildAnalysisSection() {
    return Column(
      children: [
        _buildInfoRow("Vốn gốc ban đầu", "${moneyController.text} VNĐ"),
        _buildInfoRow("Lợi nhuận dự kiến", "+100%", isHighlight: true),
        _buildInfoRow("Tổng cộng cuối kỳ", "${(double.tryParse(moneyController.text)! * 2).toStringAsFixed(0)} VNĐ"),
        const SizedBox(height: 15),
        const Text(
          "* Tính toán dựa trên lãi kép tích lũy hàng năm.",
          style: TextStyle(color: Colors.white30, fontSize: 11, fontStyle: FontStyle.italic),
        ),
      ],
    );
  }

  Widget _buildInfoRow(String label, String value, {bool isHighlight = false}) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 8),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          Text(label, style: const TextStyle(color: Colors.white70)),
          Text(value, 
            style: TextStyle(
              color: isHighlight ? Colors.cyanAccent : Colors.white, 
              fontWeight: FontWeight.bold,
              fontSize: 16,
            )),
        ],
      ),
    );
  }
}
